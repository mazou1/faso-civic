# Copier vers .env et ajuster
POSTGRES_PASSWORD=faso

# Backend (préfixe FASO_)
FASO_DATABASE_URL=postgresql+psycopg://faso:faso@localhost:5434/faso
FASO_DATA_DIR=./data
FASO_ADMIN_USER=admin
FASO_ADMIN_PASSWORD=change-me
FASO_SECRET_KEY=change-me-long-random
# Extraction LLM des comptes rendus (décisions + nominations)
FASO_LLM_PROVIDER=mistral              # mistral (tier gratuit) | anthropic
FASO_MISTRAL_API_KEY=...               # console.mistral.ai → API keys (plan Experiment gratuit)
# FASO_ANTHROPIC_API_KEY=sk-ant-...   # si FASO_LLM_PROVIDER=anthropic
