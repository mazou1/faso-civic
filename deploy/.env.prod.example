# Configuration de production — copier en .env À LA RACINE du dépôt sur le VPS
#   cp deploy/.env.prod.example .env   puis éditer.
# NE JAMAIS committer le .env rempli (il est déjà gitignoré).

# --- Domaine & HTTPS -----------------------------------------------------------
DOMAIN=faso.example.org
ACME_EMAIL=admin@example.org           # e-mail Let's Encrypt (alertes expiration)

# --- Base de données -----------------------------------------------------------
# Générer : openssl rand -base64 24
POSTGRES_PASSWORD=REMPLACER_mot_de_passe_postgres

# --- Back-office / API ---------------------------------------------------------
FASO_ADMIN_USER=admin
# Générer : openssl rand -base64 24
FASO_ADMIN_PASSWORD=REMPLACER_mot_de_passe_admin_fort
# Générer : openssl rand -hex 32
FASO_SECRET_KEY=REMPLACER_cle_secrete_longue_aleatoire

# --- Extraction LLM ------------------------------------------------------------
FASO_LLM_PROVIDER=mistral
FASO_MISTRAL_API_KEY=REMPLACER_cle_mistral   # tier gratuit suffisant
FASO_ANTHROPIC_API_KEY=                       # optionnel (fallback Claude)
